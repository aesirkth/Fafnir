/dts-v1/;
#include <st/u5/stm32u575Xg.dtsi>
#include <st/u5/stm32u575rgtx-pinctrl.dtsi>
#include <zephyr/dt-bindings/input/input-event-codes.h>


/ {

	chosen {
		zephyr,sram = &sram0;
		zephyr,flash = &flash0;
		zephyr,canbus = &fdcan1;
	};

	aliases {
		
		fdcan1 = &fdcan1;


		rxled = &rx_led;

		n2valve = &solenoid0;
		ventvalve = &solenoid1;
		abortvalve = &solenoid2;
		extravalve = &solenoid3;

		n2sense = &solenoid_sense0;
		ventsense = &solenoid_sense1;
		abortsense = &solenoid_sense2;
		extrasense = &solenoid_sense3;

		servo = &servo_motor;

	};


    leds {
        compatible = "gpio-leds";
        
        rx_led: led_0 {
			gpios = <&gpiob 4 GPIO_ACTIVE_HIGH>;
		};
    };

	solenoids {
        compatible = "gpio-leds";
        
        solenoid0: sol_0 {
			gpios = <&gpioa 12 GPIO_ACTIVE_HIGH>;
		};

		solenoid1: sol_1 {
			gpios = <&gpioa 11 GPIO_ACTIVE_HIGH>;
		};

		solenoid2: sol_2 {
			gpios = <&gpioa 10 GPIO_ACTIVE_HIGH>;
		};

		solenoid3: sol_3 {
			gpios = <&gpioa 9 GPIO_ACTIVE_HIGH>;
		};

	};

	solenoidSense {
        compatible = "gpio-keys";
        
        solenoid_sense0: sense_0 {
			gpios = <&gpiob 15 GPIO_ACTIVE_LOW>;
		};

		solenoid_sense1: sense_1 {
			gpios = <&gpiob 13 GPIO_ACTIVE_LOW>;
		};
		
		solenoid_sense2: sense_2 {
			gpios = <&gpiob 12 GPIO_ACTIVE_LOW>;
		};

		solenoid_sense3: sense_3 {
			gpios = <&gpiob 2 GPIO_ACTIVE_LOW>;
		};

	};

	servo {
		compatible = "pwm-leds";
		status = "okay";

		servo_motor: servo {
			pwms = <&pwm3 3 PWM_MSEC(20) PWM_POLARITY_NORMAL>;
		};
	};

};


&timers3 {
    st,prescaler = <900>;
	status = "okay";

	pwm3: pwm {
		status = "okay";
		pinctrl-0 = <&tim3_ch3_pb0>;
		pinctrl-names = "default";
	};
};


&clk_hse {
    clock-frequency = <DT_FREQ_M(24)>; /* your crystal MHz */
    status = "okay";
};

&pll1 {
	div-m = <2>;
	mul-n = <30>;
	div-q = <4>;
	div-r = <4>;
	clocks = <&clk_hse>;
	status = "okay";
};

&rcc {
	clocks = <&pll1>;
	clock-frequency = <DT_FREQ_M(90)>;
	ahb-prescaler = <1>;
	apb1-prescaler = <1>;
	apb2-prescaler = <1>;
	apb3-prescaler = <1>;
};

&fdcan1 {
	clocks = <&rcc STM32_CLOCK_BUS_APB1_2 0x00000200>,
		 <&rcc STM32_SRC_PLL1_Q FDCAN1_SEL(1)>;
	pinctrl-0 = <&fdcan1_rx_pb8 &fdcan1_tx_pb9>;
	pinctrl-names = "default";
	status = "okay";
};